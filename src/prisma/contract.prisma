// use prisma-next

model Poi {
  id        Int      @id @default(autoincrement())
  name      String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt temporal.updatedAt()
}

// Per-POI forecast cache; refreshed when the covering ICON model publishes a new run.
model PoiForecast {
  poiId     Int      @id
  poi       Poi      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  model     String
  hourly    Json
  fetchedAt DateTime // drives UTC-day-rollover invalidation
  staleAt   DateTime // covering model's next-run instant
}
