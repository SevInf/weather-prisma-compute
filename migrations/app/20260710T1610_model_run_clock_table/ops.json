  {
    "id": "checkConstraint.modelRun.modelRun_model_check",
    "label": "Add check constraint \"modelRun_model_check\" on \"modelRun\".\"model\"",
    "operationClass": "additive",
    "target": {
      "id": "postgres",
      "details": {
        "schema": "public",
        "objectType": "checkConstraint",
        "name": "modelRun_model_check",
        "table": "modelRun"
      }
    },
    "precheck": [
      {
        "description": "ensure constraint \"modelRun_model_check\" does not exist",
        "sql": "SELECT NOT EXISTS (SELECT 1 AS \"one\" FROM \"pg_constraint\" AS \"c\" INNER JOIN \"pg_namespace\" AS \"n\" ON \"n\".\"oid\" = \"c\".\"connamespace\" WHERE (\"c\".\"conname\" = $1 AND \"n\".\"nspname\" = $2 AND \"c\".\"conrelid\" = to_regclass($3))) AS \"result\"",
