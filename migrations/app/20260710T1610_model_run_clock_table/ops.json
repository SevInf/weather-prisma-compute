    ],
    "execute": [
      {
        "description": "add check constraint \"modelRun_model_check\"",
        "sql": "ALTER TABLE \"public\".\"modelRun\" ADD CONSTRAINT \"modelRun_model_check\" CHECK (\"model\" IN ('dwd_icon_d2', 'dwd_icon_eu', 'dwd_icon'))"
